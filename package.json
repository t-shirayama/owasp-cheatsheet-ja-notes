{
  "name": "owasp-cheatsheet-ja-notes",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial Japanese notes and bilingual views for OWASP Cheat Sheet Series mapped through ASVS.",
  "scripts": {
    "dev": "docusaurus start --host 0.0.0.0",
    "build": "docusaurus build",
    "catalog": "node tools/generate-catalog.mjs",
    "catalog:check": "node tools/generate-catalog.mjs --check",
    "navigation": "node tools/generate-bilingual-samples.mjs --navigation-only",
    "lint:md": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/Invoke-MarkdownLint.ps1",
    "check:links": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/Invoke-LinkCheck.ps1",
    "check": "npm run lint:md && npm run check:links && npm run build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@easyops-cn/docusaurus-search-local": "0.55.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  }
}
